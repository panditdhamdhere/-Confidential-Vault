SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0xyourprivatekey
# Etherscan API key — https://etherscan.io/apis (same key works for Sepolia)
ETHERSCAN_API_KEY=yourEtherscanApiKey
# Deployed vault (for npm run verify:sepolia)
VAULT_CONTRACT_ADDRESS=0xYourDeployedVaultAddress
# Optional: if owner/officer differ from deployer-derived addresses
# VAULT_OWNER_ADDRESS=0x...
# VAULT_COMPLIANCE_OFFICER_ADDRESS=0x...
